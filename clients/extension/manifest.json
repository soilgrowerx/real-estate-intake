{
    "manifest_version": 3,
    "name": "Neocambrian Spore Clipper",
    "version": "1.0",
    "description": "Harvest thoughts, links, and text directly into your Sovereign Garden.",
    "icons": {
        "48": "icon.png"
    },
    "permissions": [
        "activeTab",
        "scripting",
        "storage"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_title": "Harvest Spore"
    },
    "background": {
        "service_worker": "background.js"
    }
}